# ─────────────────────────────────────────────
#  Sweet Salad — Configuration
#  Renommez ce fichier en .env avant de démarrer
# ─────────────────────────────────────────────

# Twilio — récupérez ces valeurs sur console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Port du serveur (Render/Railway utilisent 3000 par défaut)
PORT=3000
